// ============================================================
// Orders & Order Items (PRD Section 17.1, 17.2)
// ============================================================

model Order {
  id                        String    @id @default(cuid())
  orderNumber               String    @unique
  memberId                  String?
  orderStatus               String    @default("CREATED")
  currency                  String    @default("TWD")
  // 商品金額
  originalItemAmount        Decimal   @db.Decimal(18, 2) @default(0)  // 商品原價合計
  finalItemAmountBeforeCoupon Decimal @db.Decimal(18, 2) @default(0)  // 會員/活動價擇優後合計
  // 優惠券
  totalPlatformCouponAmount Decimal   @db.Decimal(18, 2) @default(0)  // 平台券折扣總額
  totalMerchantCouponAmount Decimal   @db.Decimal(18, 2) @default(0)  // 商家券折扣總額
  // 嗨幣
  hiCoinMaxUsableAmount     Decimal   @db.Decimal(18, 2) @default(0)  // 嗨幣可折抵上限 (券折後×50%)
  hiCoinTotalUsed           Decimal   @db.Decimal(18, 2) @default(0)  // 嗨幣實際使用
  // 金額
  shippingTotalAmount       Decimal   @db.Decimal(18, 2) @default(0)  // 運費合計
  cashTotalPaid             Decimal   @db.Decimal(18, 2) @default(0)  // 現金實付合計
  // 狀態
  expectedProfitStatus      Boolean   @default(false)                  // 可預期獲利訂單
  cancelFlag                Boolean   @default(false)
  cancelReason              String?
  // 時間
  paidAt                    DateTime?
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt

  items      OrderItem[]
  subOrders  SubOrder[]
  payment    PaymentTransaction?
  refunds    Refund[]

  @@map("orders")
}

model OrderItem {
  id                        String    @id @default(cuid())
  orderId                   String
  order                     Order     @relation(fields: [orderId], references: [id])
  productId                 String?
  merchantId                String
  categoryId                String?
  skuId                     String?
  quantity                  Int       @default(1)
  // 價格
  originalPrice             Decimal   @db.Decimal(18, 2) @default(0)  // 原價
  memberPrice               Decimal?  @db.Decimal(18, 2)              // 會員價
  campaignPrice             Decimal?  @db.Decimal(18, 2)              // 活動價
  finalPriceBeforeHiCoin    Decimal   @db.Decimal(18, 2) @default(0)  // 最終成交價(嗨幣前)
  // 優惠券
  platformCouponAmount      Decimal   @db.Decimal(18, 2) @default(0)  // 平台券分攤
  merchantCouponAmount      Decimal   @db.Decimal(18, 2) @default(0)  // 商家券分攤
  // 結算基礎 = finalPriceBeforeHiCoin - merchantCouponAmount (不扣平台券)
  settlementBasePrice       Decimal   @db.Decimal(18, 2) @default(0)
  // 嗨幣
  hiCoinAllocableAmount     Decimal   @db.Decimal(18, 2) @default(0)  // 可折抵基礎
  hiCoinAllocatedAmount     Decimal   @db.Decimal(18, 2) @default(0)  // 實際分攤嗨幣
  // 商品名稱（展示用）
  productName               String    @default("")
  // 退款狀態
  refundStatus              String?
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt

  subOrderItems  SubOrderItem[]

  @@index([orderId])
  @@index([merchantId])
  @@map("order_items")
}

model Shipment {
  id          String    @id @default(cuid())
  subOrderId  String
  subOrder    SubOrder  @relation(fields: [subOrderId], references: [id])
  trackingNo  String?
  carrier     String?
  shippedAt   DateTime?
  deliveredAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([subOrderId])
  @@map("shipments")
}

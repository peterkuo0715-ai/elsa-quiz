// ============================================================
// Settlement Items & Batches
// ============================================================

model SettlementItem {
  id                     String               @id @default(cuid())
  orderItemId            String               @unique
  orderItem              OrderItem            @relation(fields: [orderItemId], references: [id])
  merchantId             String
  batchId                String?
  batch                  SettlementBatch?     @relation(fields: [batchId], references: [id])
  // Status
  status                      SettlementItemStatus @default(PENDING_PAYMENT)
  // === PRD v1.1 Section 14.1 Full Fields ===
  // 收入項
  productAmount               Decimal    @db.Decimal(18, 4) @default(0)  // 商品成交金額
  shippingAmount               Decimal    @db.Decimal(18, 4) @default(0)  // 運費收入
  // 扣款項
  commissionAmount             Decimal    @db.Decimal(18, 4) @default(0)  // 平台抽成
  commissionRate               Decimal    @db.Decimal(5, 4)  @default(0)  // 抽成率
  paymentFeeAmount             Decimal    @db.Decimal(18, 4) @default(0)  // 金流手續費
  promotionCostAmount          Decimal    @db.Decimal(18, 4) @default(0)  // 商家活動成本
  hiCoinRedeemedAmount         Decimal    @db.Decimal(18, 4) @default(0)  // 嗨幣折抵金額
  hiCoinCampaignCostAmount     Decimal    @db.Decimal(18, 4) @default(0)  // 嗨幣活動成本 (商家負擔)
  // 補貼項
  platformSubsidyAmount        Decimal    @db.Decimal(18, 4) @default(0)  // 平台嗨幣補貼 (模式A)
  // 調整項
  refundAdjustmentAmount       Decimal    @db.Decimal(18, 4) @default(0)  // 退款調整
  disputeAdjustmentAmount      Decimal    @db.Decimal(18, 4) @default(0)  // 爭議調整
  manualAdjustmentAmount       Decimal    @db.Decimal(18, 4) @default(0)  // 人工調整
  // 結算結果
  grossSettlementAmount        Decimal    @db.Decimal(18, 4) @default(0)  // 結算總額 (加項合計)
  netSettlementAmount          Decimal    @db.Decimal(18, 4) @default(0)  // 商家應得淨額
  cashPaidAmount               Decimal    @db.Decimal(18, 4) @default(0)  // 消費者台幣實付
  // 稅務
  taxIncludedAmount            Decimal    @db.Decimal(18, 4) @default(0)  // 含稅金額
  taxExcludedAmount            Decimal    @db.Decimal(18, 4) @default(0)  // 未稅金額
  // Reserve
  reserveAmount                Decimal    @db.Decimal(18, 4) @default(0)
  // === Legacy compat (keep for existing code) ===
  itemAmountTaxIncl            Decimal    @db.Decimal(18, 4) @default(0)
  itemAmountTaxExcl            Decimal    @db.Decimal(18, 4) @default(0)
  itemTaxAmount                Decimal    @db.Decimal(18, 4) @default(0)
  netAmountTaxIncl             Decimal    @db.Decimal(18, 4) @default(0)
  netAmountTaxExcl             Decimal    @db.Decimal(18, 4) @default(0)
  netTaxAmount                 Decimal    @db.Decimal(18, 4) @default(0)
  // Timeline
  paidAt                 DateTime?
  shippedAt              DateTime?
  deliveredAt            DateTime?
  appreciationEndsAt     DateTime?
  settledAt              DateTime?
  // Timestamps
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt

  @@index([merchantId])
  @@index([status, appreciationEndsAt])
  @@index([batchId])
  @@map("settlement_items")
}

model SettlementBatch {
  id             String               @id @default(cuid())
  batchNumber    String               @unique
  status         SettlementBatchStatus @default(PENDING)
  totalItems     Int                  @default(0)
  totalAmount    Decimal              @db.Decimal(18, 4) @default(0)
  successCount   Int                  @default(0)
  failedCount    Int                  @default(0)
  triggeredBy    String?
  startedAt      DateTime?
  completedAt    DateTime?
  errorMessage   String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  items SettlementItem[]

  @@index([status])
  @@map("settlement_batches")
}

// ============================================================
// Manual Adjustments
// ============================================================

model SettlementAdjustment {
  id              String         @id @default(cuid())
  merchantId      String
  adjustmentType  AdjustmentType
  // Amount (positive = credit to merchant, negative = debit)
  amountTaxIncl   Decimal        @db.Decimal(18, 4)
  amountTaxExcl   Decimal        @db.Decimal(18, 4)
  taxAmount       Decimal        @db.Decimal(18, 4)
  reason          String
  // Reference
  referenceOrderId String?
  referenceItemId  String?
  // Approval
  createdBy       String
  approvedBy      String?
  approvedAt      DateTime?
  // Timestamps
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([merchantId])
  @@map("settlement_adjustments")
}

// ============================================================
// Refunds & Refund Items
// ============================================================

model Refund {
  id              String     @id @default(cuid())
  refundNumber    String     @unique
  orderId         String
  order           Order      @relation(fields: [orderId], references: [id])
  refundType      RefundType
  // Total refund amount
  totalAmountTaxIncl Decimal @db.Decimal(18, 4)
  totalAmountTaxExcl Decimal @db.Decimal(18, 4)
  totalTaxAmount     Decimal @db.Decimal(18, 4)
  reason          String?
  // Processing
  processedAt     DateTime?
  processedBy     String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  items RefundItem[]

  @@index([orderId])
  @@map("refunds")
}

model RefundItem {
  id              String    @id @default(cuid())
  refundId        String
  refund          Refund    @relation(fields: [refundId], references: [id])
  orderItemId     String
  orderItem       OrderItem @relation(fields: [orderItemId], references: [id])
  // Refund breakdown
  refundAmountTaxIncl    Decimal @db.Decimal(18, 4)
  refundAmountTaxExcl    Decimal @db.Decimal(18, 4)
  refundTaxAmount        Decimal @db.Decimal(18, 4)
  // Commission refunded (proportional)
  commissionRefund       Decimal @db.Decimal(18, 4) @default(0)
  // Payment fee: NOT refunded (always 0 here for clarity)
  paymentFeeRefund       Decimal @db.Decimal(18, 4) @default(0)
  // Campaign cost recovered (proportional)
  campaignCostRecovery   Decimal @db.Decimal(18, 4) @default(0)
  // Net debit to merchant = refundAmount - commissionRefund + campaignCostRecovery
  netMerchantDebit       Decimal @db.Decimal(18, 4)
  createdAt              DateTime @default(now())

  @@index([refundId])
  @@index([orderItemId])
  @@map("refund_items")
}

// ============================================================
// All shared enums - PRD 對帳結算規則 v1
// ============================================================

enum UserRole {
  SUPER_ADMIN
  PLATFORM_FINANCE
  PLATFORM_OPS
  MERCHANT_OWNER
  MERCHANT_STAFF
}

enum WalletBucket {
  PENDING
  AVAILABLE
  RESERVED
  IN_TRANSIT
}

// Ledger entry types
enum LedgerEntryType {
  // Settlement
  ORDER_PENDING_SETTLEMENT          // 付款成功，進入待結算
  SETTLEMENT_RELEASED               // 鑑賞期結束，pending → available
  // Fees
  COMMISSION_CHARGED                // 商店抽成+分類抽成
  PAYMENT_FEE_CHARGED               // 金流手續費
  INVOICE_FEE_CHARGED               // 發票費 (固定2元/子單)
  SHIPPING_INCOME                   // 運費收入
  // HiCoin
  HI_COIN_PLATFORM_SUBSIDY          // 平台嗨幣補貼（記錄用）
  // Rewards (PRD v3)
  REFERRAL_REWARD_DEDUCTION         // 推薦碼獎勵扣款（商家承擔）
  LIST_GUIDE_REWARD_DEDUCTION       // 清單導購獎勵扣款（商家承擔）
  // Refund
  REFUND_DEBIT                      // 全額退款扣回
  PARTIAL_REFUND_DEBIT              // 部分退款扣回
  REFUND_COMMISSION_RETURN          // 退款抽成回沖
  // Dispute
  DISPUTE_FREEZE_HOLD               // 爭議凍結
  DISPUTE_FREEZE_RELEASE            // 爭議解凍
  DISPUTE_DEBIT                     // 爭議判定扣回
  // Reserve
  RESERVE_HOLD
  RESERVE_RELEASE
  // Payout
  PAYOUT_REQUESTED                  // 提領申請
  PAYOUT_SENT                       // 提領成功
  PAYOUT_FAILED_RETURN              // 提領失敗退回
  // Manual
  MANUAL_ADJUSTMENT_CREDIT
  MANUAL_ADJUSTMENT_DEBIT
  // System
  REVERSAL                          // 沖銷
  NEGATIVE_BALANCE_CARRY            // 負餘額結轉
  PLATFORM_ABSORBED                 // 平台吸收差額 (商家最低保護0)
}

// 子單狀態 (PRD Section 9.2)
enum SubOrderStatus {
  EXPECTED_PROFIT                   // 可預期獲利訂單
  PENDING_SHIPMENT                  // 待出貨
  SHIPPED                           // 已出貨
  IN_TRANSIT                        // 運送中
  DELIVERED                         // 已送達/已取貨
  APPRECIATION_PERIOD               // 鑑賞期倒數中
  SETTLEABLE                        // 可結算
  SETTLED                           // 已結算
  DISPUTED                          // 爭議中
  CANCELLED                         // 已取消
}

// 結算狀態
enum SettlementStatus {
  EXPECTED                          // 可預期獲利
  AVAILABLE                         // 可結算
  SETTLED                           // 已結算
}

enum PayoutRequestStatus {
  REQUESTED
  QUEUED
  PROCESSING
  SUCCESS
  FAILED
  RETURNED
}

enum PayoutBatchStatus {
  CREATED
  EXPORTED
  PROCESSING
  COMPLETED
  PARTIALLY_FAILED
}

enum DisputeStatus {
  OPENED
  WAITING_MERCHANT_RESPONSE
  WAITING_PLATFORM_REVIEW
  EVIDENCE_PENDING
  PARTIALLY_FROZEN
  RESOLVED
  REJECTED
  CLOSED
}

enum BankAccountChangeStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
  EFFECTIVE
}

enum MerchantRiskLevel {
  LOW
  MEDIUM
  HIGH
}

enum AdjustmentType {
  SUPPLEMENTARY_PAYMENT
  CLAWBACK
  COMPLAINT_COMPENSATION
  DISCREPANCY_CORRECTION
  TAX_ADJUSTMENT
  SYSTEM_CORRECTION
}

enum RefundType {
  FULL
  PARTIAL
  NEGOTIATED             // 協商退款
  ADJUDICATED            // 平台裁決退款
}

enum RefundStatus {
  REQUESTED
  APPROVED
  COMPLETED
  REJECTED
}

enum ReferenceType {
  ORDER
  ORDER_ITEM
  SUB_ORDER
  SUB_ORDER_ITEM
  REFUND
  REFUND_ITEM
  PAYOUT_REQUEST
  PAYOUT_BATCH_ITEM
  DISPUTE_CASE
  DISPUTE_FREEZE
  SETTLEMENT_ADJUSTMENT
  RESERVE_RULE
}

// 優惠券類型
enum PromotionType {
  PLATFORM_COUPON         // 平台券
  MERCHANT_COUPON         // 商家券
  CAMPAIGN                // 活動優惠
}

// 出資方
enum SponsorType {
  PLATFORM
  MERCHANT
}

// 快照類型
enum SnapshotType {
  EXPECTED_PROFIT         // 可預期獲利
  AVAILABLE_SETTLEMENT    // 可結算
  SETTLED                 // 已結算
}
